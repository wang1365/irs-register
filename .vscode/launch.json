{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Run Auto Registry",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONIOENCODING": "utf-8"
      }
    }
  ]
}
